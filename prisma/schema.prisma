generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BookClub {
  id           String            @id @default(uuid())
  name         String
  description  String?
  isPublic     Boolean           @default(true)
  genre        String?
  coverImage   String?
  createdAt    DateTime          @default(now())
  members      ClubMember[]
  joinRequests ClubJoinRequest[]
  chatRooms    ChatRoom[]
  chatMessages ChatMessage[]
  readingCycles ReadingCycle[]
  discussionTopics DiscussionTopic[]
  bookVoteRounds BookVoteRound[]
}

model Book {
  id             String   @id @default(uuid())
  title          String
  subtitle       String?
  description    String?
  authors        String[] @default([])
  coverImage     String?
  isbn10         String?  @unique
  isbn13         String?  @unique
  publisher      String?
  publishedDate  String?
  pageCount      Int?
  language       String?
  externalSource String?
  externalId     String?
  previewUrl     String?
  infoUrl        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  readingCycles  ReadingCycle[]
  nominations    BookNomination[]

  @@unique([externalSource, externalId])
  @@index([title])
  @@index([isbn13])
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  username         String            @unique
  avatarUrl        String?
  bio              String?
  favoriteGenres   String[]          @default([])
  passwordHash     String?
  role             Role              @default(USER)
  isEmailVerified  Boolean           @default(false)
  isActive         Boolean           @default(true)
  provider         AuthProvider      @default(LOCAL)
  providerId       String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  clubMemberships  ClubMember[]
  joinRequests     ClubJoinRequest[] @relation("RequestedByUser")
  reviewedRequests ClubJoinRequest[] @relation("ReviewedBy")
  chatMessages     ChatMessage[]
  createdReadingCycles ReadingCycle[]
  readingProgress  ReadingProgress[]
  discussionTopics DiscussionTopic[]
  discussionPosts  DiscussionPost[]
  createdBookVoteRounds BookVoteRound[]
  bookNominations BookNomination[]
  bookVotes       BookVote[]
}

model ReadingCycle {
  id              String             @id @default(uuid())
  clubId          String
  bookId          String
  status          ReadingCycleStatus @default(PLANNED)
  startDate       DateTime
  targetEndDate   DateTime
  goalDescription String?
  createdByUserId String
  startedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  club      BookClub @relation(fields: [clubId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Restrict)
  createdBy User     @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  progress  ReadingProgress[]
  targets   ReadingTarget[]
  discussionTopics DiscussionTopic[]

  @@index([clubId, status])
  @@index([bookId])
  @@index([createdByUserId])
  @@index([startDate])
}

model ReadingTarget {
  id             String            @id @default(uuid())
  readingCycleId String
  sequence       Int
  title          String
  description    String?
  targetType     ReadingTargetType
  startValue     Int?
  endValue       Int?
  startDate      DateTime
  endDate        DateTime
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  readingCycle ReadingCycle @relation(fields: [readingCycleId], references: [id], onDelete: Cascade)
  discussionTopics DiscussionTopic[]

  @@unique([readingCycleId, sequence])
  @@index([readingCycleId])
  @@index([readingCycleId, sequence])
  @@index([startDate])
}

model ReadingProgress {
  id                 String                @id @default(uuid())
  readingCycleId     String
  userId             String
  status             ReadingProgressStatus @default(NOT_STARTED)
  progressPercentage Int                   @default(0)
  startedAt          DateTime?
  completedAt        DateTime?
  lastUpdatedAt      DateTime
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  readingCycle ReadingCycle @relation(fields: [readingCycleId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([readingCycleId, userId])
  @@index([readingCycleId])
  @@index([userId])
  @@index([status])
  @@index([lastUpdatedAt])
}

model ClubMember {
  id       String         @id @default(uuid())
  userId   String
  clubId   String
  role     ClubMemberRole @default(MEMBER)
  joinedAt DateTime       @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  club BookClub @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
  @@index([clubId])
  @@index([userId])
}

model ClubJoinRequest {
  id               String                @id @default(uuid())
  clubId           String
  userId           String
  status           ClubJoinRequestStatus @default(PENDING)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  reviewedAt       DateTime?
  reviewedByUserId String?

  club       BookClub @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user       User     @relation("RequestedByUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User?    @relation("ReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@unique([userId, clubId])
  @@index([clubId])
  @@index([userId])
  @@index([status])
}

model ChatRoom {
  id        String   @id @default(cuid())
  clubId    String
  name      String?
  createdAt DateTime @default(now())

  club     BookClub      @relation(fields: [clubId], references: [id])
  messages ChatMessage[]

  @@index([clubId])
}

model ChatMessage {
  id        String    @id @default(cuid())
  roomId    String
  clubId    String
  userId    String
  content   String
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  room ChatRoom @relation(fields: [roomId], references: [id])
  user User     @relation(fields: [userId], references: [id])
  club BookClub @relation(fields: [clubId], references: [id])

  @@index([clubId, roomId, createdAt])
}

model DiscussionTopic {
  id              String              @id @default(uuid())
  clubId          String
  readingCycleId  String?
  readingTargetId String?
  createdByUserId String
  title           String
  prompt          String?
  topicType       DiscussionTopicType @default(GENERAL)
  isPinned        Boolean             @default(false)
  isLocked        Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?

  club          BookClub       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  readingCycle  ReadingCycle?  @relation(fields: [readingCycleId], references: [id], onDelete: SetNull)
  readingTarget ReadingTarget? @relation(fields: [readingTargetId], references: [id], onDelete: SetNull)
  createdBy     User           @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  posts         DiscussionPost[]

  @@index([clubId, isPinned, createdAt])
  @@index([readingCycleId])
  @@index([readingTargetId])
  @@index([createdByUserId])
  @@index([deletedAt])
}

model DiscussionPost {
  id           String    @id @default(uuid())
  topicId      String
  userId       String
  parentPostId String?
  content      String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  topic       DiscussionTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentPost  DiscussionPost? @relation("DiscussionPostReplies", fields: [parentPostId], references: [id], onDelete: SetNull)
  replies     DiscussionPost[] @relation("DiscussionPostReplies")

  @@index([topicId, createdAt])
  @@index([userId])
  @@index([parentPostId])
  @@index([deletedAt])
}

model BookVoteRound {
  id                 String              @id @default(uuid())
  clubId             String
  title              String
  description        String?
  status             BookVoteRoundStatus @default(DRAFT)
  opensAt            DateTime?
  closesAt           DateTime?
  createdByUserId    String
  winnerNominationId String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  closedAt           DateTime?

  club             BookClub         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdBy        User             @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  nominations      BookNomination[]
  votes            BookVote[]
  winnerNomination BookNomination?  @relation("VoteRoundWinner", fields: [winnerNominationId], references: [id], onDelete: SetNull)

  @@index([clubId, status])
  @@index([createdByUserId])
  @@index([winnerNominationId])
}

model BookNomination {
  id                String    @id @default(uuid())
  voteRoundId       String
  bookId            String
  nominatedByUserId String
  reason            String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  withdrawnAt       DateTime?

  voteRound     BookVoteRound   @relation(fields: [voteRoundId], references: [id], onDelete: Cascade)
  book          Book            @relation(fields: [bookId], references: [id], onDelete: Restrict)
  nominatedBy   User            @relation(fields: [nominatedByUserId], references: [id], onDelete: Cascade)
  votes         BookVote[]
  winningRounds BookVoteRound[] @relation("VoteRoundWinner")

  @@unique([voteRoundId, bookId])
  @@unique([voteRoundId, nominatedByUserId])
  @@index([voteRoundId])
  @@index([bookId])
  @@index([nominatedByUserId])
  @@index([withdrawnAt])
}

model BookVote {
  id           String   @id @default(uuid())
  voteRoundId  String
  nominationId String
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  voteRound  BookVoteRound  @relation(fields: [voteRoundId], references: [id], onDelete: Cascade)
  nomination BookNomination @relation(fields: [nominationId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([voteRoundId, userId])
  @@index([voteRoundId])
  @@index([nominationId])
  @@index([userId])
}

enum Role {
  USER
  ADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
  GITHUB
}

enum ClubMemberRole {
  MEMBER
  MODERATOR
  OWNER
}

enum ClubJoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReadingCycleStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ReadingProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum ReadingTargetType {
  CHAPTERS
  PAGES
  CUSTOM
}

enum DiscussionTopicType {
  GENERAL
  READING_CYCLE
  READING_TARGET
  PROMPT
}

enum BookVoteRoundStatus {
  DRAFT
  OPEN
  CLOSED
  CANCELLED
}
